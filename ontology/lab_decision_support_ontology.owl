<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/lab_decision_support.owl#"
     xml:base="http://example.org/lab_decision_support.owl"
     xmlns:cl="http://purl.obolibrary.org/obo/cl#"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:go="http://purl.obolibrary.org/obo/go#"
     xmlns:hp="http://purl.obolibrary.org/obo/hp#"
     xmlns:pr="http://purl.obolibrary.org/obo/pr#"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:core="http://purl.obolibrary.org/obo/uberon/core#"
     xmlns:doid="http://purl.obolibrary.org/obo/doid#"
     xmlns:pato="http://purl.obolibrary.org/obo/pato#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:chebi="http://purl.obolibrary.org/obo/chebi#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:chebi1="http://purl.obolibrary.org/obo/chebi#2"
     xmlns:chebi2="http://purl.obolibrary.org/obo/chebi#3"
     xmlns:chebi3="http://purl.obolibrary.org/obo/chebi#1"
     xmlns:ubprop="http://purl.obolibrary.org/obo/ubprop#"
     xmlns:subsets="http://purl.obolibrary.org/obo/ro/subsets#"
     xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#">
    <owl:Ontology rdf:about="http://example.org/lab_decision_support.owl">
        <owl:imports rdf:resource="http://purl.obolibrary.org/obo/doid/releases/2026-04-30/doid.owl"/>
        <owl:imports rdf:resource="http://purl.obolibrary.org/obo/hp/releases/2026-02-16/hp-full.owl"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/lab_decision_support.owl#diseaseHasAction -->

    <owl:ObjectProperty rdf:about="http://example.org/lab_decision_support.owl#diseaseHasAction">
        <rdfs:domain rdf:resource="http://example.org/lab_decision_support.owl#Disease_Candidate"/>
        <rdfs:range rdf:resource="http://example.org/lab_decision_support.owl#Recommended_Action"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/lab_decision_support.owl#diseaseHasUrgency -->

    <owl:ObjectProperty rdf:about="http://example.org/lab_decision_support.owl#diseaseHasUrgency">
        <rdfs:domain rdf:resource="http://example.org/lab_decision_support.owl#Disease_Candidate"/>
        <rdfs:range rdf:resource="http://example.org/lab_decision_support.owl#Urgency_Level"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/lab_decision_support.owl#diseaseRequiresTest -->

    <owl:ObjectProperty rdf:about="http://example.org/lab_decision_support.owl#diseaseRequiresTest">
        <rdfs:domain rdf:resource="http://example.org/lab_decision_support.owl#Disease_Candidate"/>
        <rdfs:range rdf:resource="http://example.org/lab_decision_support.owl#Additional_Test"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/lab_decision_support.owl#diseaseSuggestedByFinding -->

    <owl:ObjectProperty rdf:about="http://example.org/lab_decision_support.owl#diseaseSuggestedByFinding">
        <owl:inverseOf rdf:resource="http://example.org/lab_decision_support.owl#findingSuggestsDisease"/>
        <rdfs:domain rdf:resource="http://example.org/lab_decision_support.owl#Disease_Candidate"/>
        <rdfs:range rdf:resource="http://example.org/lab_decision_support.owl#Finding"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/lab_decision_support.owl#diseaseTreatedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/lab_decision_support.owl#diseaseTreatedBy">
        <rdfs:domain rdf:resource="http://example.org/lab_decision_support.owl#Disease_Candidate"/>
        <rdfs:range rdf:resource="http://example.org/lab_decision_support.owl#Specialist"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/lab_decision_support.owl#findingSuggestsDisease -->

    <owl:ObjectProperty rdf:about="http://example.org/lab_decision_support.owl#findingSuggestsDisease">
        <rdfs:domain rdf:resource="http://example.org/lab_decision_support.owl#Finding"/>
        <rdfs:range rdf:resource="http://example.org/lab_decision_support.owl#Disease_Candidate"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/lab_decision_support.owl#hasLabTest -->

    <owl:ObjectProperty rdf:about="http://example.org/lab_decision_support.owl#hasLabTest">
        <rdfs:domain rdf:resource="http://example.org/lab_decision_support.owl#Lab_Panel"/>
        <rdfs:range rdf:resource="http://example.org/lab_decision_support.owl#Lab_Test"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/lab_decision_support.owl#hasPatientFactor -->

    <owl:ObjectProperty rdf:about="http://example.org/lab_decision_support.owl#hasPatientFactor">
        <rdfs:domain rdf:resource="http://example.org/lab_decision_support.owl#Lab_Panel"/>
        <rdfs:range rdf:resource="http://example.org/lab_decision_support.owl#Patient_Factor"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/lab_decision_support.owl#labTestIndicatesFinding -->

    <owl:ObjectProperty rdf:about="http://example.org/lab_decision_support.owl#labTestIndicatesFinding">
        <rdfs:domain rdf:resource="http://example.org/lab_decision_support.owl#Lab_Test"/>
        <rdfs:range rdf:resource="http://example.org/lab_decision_support.owl#Finding"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/lab_decision_support.owl#patientFactorIndicatesFinding -->

    <owl:ObjectProperty rdf:about="http://example.org/lab_decision_support.owl#patientFactorIndicatesFinding">
        <rdfs:domain rdf:resource="http://example.org/lab_decision_support.owl#Patient_Factor"/>
        <rdfs:range rdf:resource="http://example.org/lab_decision_support.owl#Finding"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/lab_decision_support.owl#ALP -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#ALP">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Lab_Test"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#labTestIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#High_ALP"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#ALT -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#ALT">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Lab_Test"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#labTestIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Elevated_ALT"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#labTestIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Hepatic_Cell_Injury"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#AST -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#AST">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Lab_Test"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#labTestIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Elevated_AST"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#labTestIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Liver_Damage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#Abnormal_Platelets -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#Abnormal_Platelets">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Finding"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#findingSuggestsDisease"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Leukemia_Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#findingSuggestsDisease"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Platelet_Disorder"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#Additional_Test -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#Additional_Test">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Recommendation"/>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#Age -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#Age">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Patient_Factor"/>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#Albumin -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#Albumin">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Lab_Test"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#labTestIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Hypoalbuminemia"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#labTestIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Liver_Synthetic_Dysfunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#Anemia_Other -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#Anemia_Other">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Disease_Candidate"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#diseaseHasAction"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Order_Confirmatory_Test"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#diseaseHasUrgency"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Soon"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#diseaseRequiresTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Peripheral_Smear"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#diseaseRequiresTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Repeat_Lab_Test"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#diseaseTreatedBy"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Hematologist"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#Anti_TPO -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#Anti_TPO">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Additional_Test"/>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#BMI -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#BMI">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Patient_Factor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#patientFactorIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Insulin_Resistance_Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#patientFactorIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Obesity_Finding"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#BUN -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#BUN">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Lab_Test"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#labTestIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Elevated_BUN"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#labTestIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Kidney_Function_Impairment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#Basophils -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#Basophils">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Lab_Test"/>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#Bilirubin -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#Bilirubin">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Lab_Test"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#labTestIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Hyperbilirubinemia"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#labTestIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Jaundice_Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#Blood_Glucose -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#Blood_Glucose">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Lab_Test"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#labTestIndicatesFinding"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Hyperglycemia"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#Bone_Marrow_Biopsy -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#Bone_Marrow_Biopsy">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Additional_Test"/>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#CBC_Panel -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#CBC_Panel">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Lab_Panel"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Basophils"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Eosinophils"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Hematocrit"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Hemoglobin"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Lymphocytes"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#MCH"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#MCHC"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#MCV"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Monocytes"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Neutrophils"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Platelets"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#RBC"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#RDW"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#hasLabTest"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#WBC"/>
            </owl:Restriction>
