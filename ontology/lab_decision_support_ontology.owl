    <!-- http://example.org/lab_decision_support.owl#CRP -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#CRP">
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Additional_Test"/>
    </owl:Class>
    


    <!-- http://example.org/lab_decision_support.owl#Chronic_Kidney_Disease -->

    <owl:Class rdf:about="http://example.org/lab_decision_support.owl#Chronic_Kidney_Disease">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.org/lab_decision_support.owl#Disease_Candidate"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#diseaseSuggestedByFinding"/>
                        <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#High_Creatinine"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#diseaseSuggestedByFinding"/>
                        <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Low_eGFR"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://example.org/lab_decision_support.owl#Disease_Candidate"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/DOID_784"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#diseaseHasAction"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Refer_To_Specialist"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#diseaseHasUrgency"/>
                <owl:someValuesFrom rdf:resource="http://example.org/lab_decision_support.owl#Soon"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/lab_decision_support.owl#diseaseRequiresTest"/>
